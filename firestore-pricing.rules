rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // HELPER FUNCTIONS
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'super_admin';
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || isSuperAdmin());
    }
    
    function hasPermission(permission) {
      return isAuthenticated() && 
             (isSuperAdmin() || 
              (getUserData().permissions != null && 
               permission in getUserData().permissions));
    }
    
    function canManagePricing() {
      return isSuperAdmin() || hasPermission('manage_pricing');
    }
    
    function canCreateOffers() {
      return isSuperAdmin() || hasPermission('create_offers') || isAdmin();
    }
    
    // ========================================
    // SUBSCRIPTION PLANS
    // ========================================
    
    match /subscription_plans/{planId} {
      // الجميع يمكنهم قراءة الباقات النشطة
      allow read: if true;
      
      // فقط المدراء يمكنهم تعديل الباقات
      allow create: if canManagePricing();
      allow update: if canManagePricing();
      allow delete: if isSuperAdmin();
      
      // التحقق من صحة البيانات عند الكتابة
      allow write: if canManagePricing() &&
                     request.resource.data.keys().hasAll(['name', 'key', 'basePrice', 'currency', 'duration']) &&
                     request.resource.data.basePrice is number &&
                     request.resource.data.basePrice > 0 &&
                     request.resource.data.currency == 'USD' &&
                     request.resource.data.duration is number &&
                     request.resource.data.key in ['monthly', 'quarterly', 'yearly'];
    }
    
    // ========================================
    // PRICING OVERRIDES
    // ========================================
    
    match /pricing_overrides/{overrideId} {
      // المستخدمون المُسجلون يمكنهم قراءة التخصيصات النشطة
      allow read: if isAuthenticated();
      
      // فقط Super Admin يمكنه إدارة التخصيصات
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
      
      // التحقق من صحة البيانات
      allow write: if isSuperAdmin() &&
                     request.resource.data.keys().hasAll(['planKey', 'discountType', 'discountValue', 'isActive']) &&
                     request.resource.data.planKey in ['monthly', 'quarterly', 'yearly'] &&
                     request.resource.data.discountType in ['percentage', 'fixed'] &&
                     request.resource.data.discountValue is number &&
                     request.resource.data.discountValue >= 0 &&
                     (request.resource.data.discountType != 'percentage' || request.resource.data.discountValue <= 100);
    }
    
    // ========================================
    // PROMOTIONAL OFFERS
    // ========================================
    
    match /promotional_offers/{offerId} {
      // الجميع يمكنهم قراءة العروض النشطة
      allow read: if true;
      
      // المدراء يمكنهم إنشاء وتعديل العروض
      allow create: if canCreateOffers();
      allow update: if canCreateOffers();
      allow delete: if isSuperAdmin();
      
      // التحقق من صحة البيانات
      allow write: if canCreateOffers() &&
                     request.resource.data.keys().hasAll(['name', 'offerType', 'discountType', 'discountValue', 'startDate', 'endDate', 'status']) &&
                     request.resource.data.offerType in ['flash_sale', 'seasonal', 'partnership', 'early_bird'] &&
                     request.resource.data.discountType in ['percentage', 'fixed'] &&
                     request.resource.data.discountValue is number &&
                     request.resource.data.discountValue > 0 &&
                     request.resource.data.status in ['draft', 'scheduled', 'active', 'expired', 'paused'] &&
                     request.resource.data.startDate is timestamp &&
                     request.resource.data.endDate is timestamp &&
                     request.resource.data.endDate > request.resource.data.startDate &&
                     (request.resource.data.discountType != 'percentage' || request.resource.data.discountValue <= 100);
    }
    
    // ========================================
    // PARTNER PRICING
    // ========================================
    
    match /partner_pricing/{partnerId} {
      // فقط Super Admin يمكنه رؤية بيانات الشركاء
      allow read: if isSuperAdmin();
      
      // فقط Super Admin يمكنه إدارة الشركاء
      allow create, update, delete: if isSuperAdmin();
      
      // التحقق من صحة البيانات
      allow write: if isSuperAdmin() &&
                     request.resource.data.keys().hasAll(['partnerName', 'partnerCode', 'partnerType', 'isPublic', 'status']) &&
                     request.resource.data.partnerType in ['federation', 'league', 'government', 'corporate'] &&
                     request.resource.data.status in ['active', 'inactive', 'pending'] &&
                     request.resource.data.isPublic is bool &&
                     request.resource.data.partnerCode is string &&
                     request.resource.data.partnerCode.size() >= 4;
    }
    
    // ========================================
    // USAGE TRACKING (للعروض والشركاء)
    // ========================================
    
    match /offer_usage/{usageId} {
      // قراءة محدودة
      allow read: if isAuthenticated() && 
                    (isSuperAdmin() || resource.data.userId == request.auth.uid);
      
      // الكتابة عند استخدام العرض
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      
      // فقط النظام يمكنه التعديل
      allow update, delete: if isSuperAdmin();
    }
    
    // ========================================
    // PRICING HISTORY (تسجيل التغييرات)
    // ========================================
    
    match /pricing_history/{historyId} {
      // القراءة للمدراء فقط
      allow read: if canManagePricing();
      
      // الكتابة للنظام فقط (للتسجيل التلقائي)
      allow create: if canManagePricing();
      
      // لا يُسمح بالتعديل أو الحذف (سجل ثابت)
      allow update, delete: if false;
    }
  }
}
