# ============================================
# إعدادات نظام التخزين الموحد
# ============================================

# نوع مزود التخزين المستخدم
# الخيارات: 'supabase' | 'cloudflare' | 'hybrid'
# - supabase: استخدام Supabase فقط (الوضع الحالي)
# - cloudflare: استخدام Cloudflare R2 فقط (بعد الانتقال الكامل)
# - hybrid: استخدام كلا المزودين (أثناء فترة الانتقال)
NEXT_PUBLIC_STORAGE_PROVIDER=supabase

# ============================================
# إعدادات الوضع المزدوج (Hybrid Mode)
# ============================================

# المزود الأساسي للملفات الجديدة (في حالة hybrid mode)
# الخيارات: 'supabase' | 'cloudflare'
NEXT_PUBLIC_PRIMARY_STORAGE_PROVIDER=cloudflare

# تفعيل النسخ الاحتياطي على المزود الثانوي
# true = رفع الملفات على كلا المزودين
# false = رفع على المزود الأساسي فقط
NEXT_PUBLIC_STORAGE_BACKUP_ENABLED=false

# ============================================
# إعدادات Supabase Storage
# ============================================

# (موجودة بالفعل في .env.local)
# NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# إعدادات Cloudflare R2
# ============================================

# Account ID من Cloudflare Dashboard
# يمكن الحصول عليه من: https://dash.cloudflare.com/ → R2 → Overview
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_ID=

# Access Key ID و Secret Access Key
# يمكن إنشاؤها من: Cloudflare Dashboard → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# رابط R2 العام (اختياري)
# إذا كنت تستخدم Custom Domain، ضعه هنا
# مثال: https://cdn.yourdomain.com
# إذا تركته فارغاً، سيستخدم: https://pub-{accountId}.r2.dev
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_URL=

# ============================================
# ملاحظات مهمة
# ============================================

# 1. للبدء بالانتقال إلى Cloudflare:
#    - غير NEXT_PUBLIC_STORAGE_PROVIDER إلى 'hybrid'
#    - غير NEXT_PUBLIC_PRIMARY_STORAGE_PROVIDER إلى 'cloudflare'
#    - املأ بيانات Cloudflare R2 أعلاه

# 2. بعد نقل جميع الملفات القديمة:
#    - غير NEXT_PUBLIC_STORAGE_PROVIDER إلى 'cloudflare'
#    - يمكنك حذف إعدادات Supabase

# 3. للنسخ الاحتياطي المزدوج:
#    - استخدم NEXT_PUBLIC_STORAGE_PROVIDER=hybrid
#    - فعّل NEXT_PUBLIC_STORAGE_BACKUP_ENABLED=true
