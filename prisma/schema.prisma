// ==========================================
// TOURNAMENT PORTAL (New System)
// ==========================================

/// العملاء الخارجيون — كل عميل يدير بطولاته الخاصة
model TournamentClient {
  id               String    @id @default(uuid())
  supabaseAuthId   String?   @unique @map("supabase_auth_id")
  name             String
  organizationName String?   @map("organization_name")
  email            String    @unique
  phone            String?
  logoUrl          String?   @map("logo_url")
  country          String?
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tournaments      TournamentNew[]

  @@map("tournament_clients")
}

/// البطولات — النظام الجديد
model TournamentNew {
  id                   String    @id @default(uuid())
  clientId             String?   @map("client_id")
  slug                 String    @unique
  name                 String
  description          String?
  logoUrl              String?   @map("logo_url")
  bannerUrl            String?   @map("banner_url")
  country              String?
  city                 String?
  location             String?
  locationUrl          String?   @map("location_url")
  startDate            String?   @map("start_date")
  endDate              String?   @map("end_date")
  registrationDeadline String?   @map("registration_deadline")
  /// draft | open | closed | ongoing | completed | cancelled
  status               String    @default("draft")
  /// knockout | league | groups_knockout
  type                 String    @default("knockout")
  maxTeams             Int?      @map("max_teams")
  minTeams             Int?      @map("min_teams")
  playersPerTeam       Int?      @map("players_per_team")
  isPublic             Boolean   @default(true) @map("is_public")
  isPaid               Boolean   @default(false) @map("is_paid")
  entryFee             Decimal?  @map("entry_fee") @db.Decimal(12, 2)
  currency             String    @default("SAR")
  paymentMethods       Json?     @map("payment_methods")
  paymentDeadline      String?   @map("payment_deadline")
  allowInstallments    Boolean   @default(false) @map("allow_installments")
  installmentsCount    Int?      @map("installments_count")
  /// team | individual
  feeType              String    @default("team") @map("fee_type")
  walletName           String?   @map("wallet_name")
  walletNumber         String?   @map("wallet_number")
  refundPolicy         String?   @map("refund_policy")
  rules                String?
  prizes               String?
  contactInfo          String?   @map("contact_info")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  client               TournamentClient?    @relation(fields: [clientId], references: [id])
  categories           TournamentCategory[]
  teams                TournamentTeam[]
  groups               TournamentGroup[]
  matches              TournamentMatch[]
  teamRegistrations    TournamentTeamReg[]
  notifications        TournamentNotif[]

  @@map("tournament_new")
}

/// فئات البطولة (U14, U17, كبار...)
model TournamentCategory {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  name          String
  ageMin        Int?      @map("age_min")
  ageMax        Int?      @map("age_max")
  maxTeams      Int?      @map("max_teams")
  /// knockout | league | groups_knockout
  type          String    @default("knockout")
  groupCount    Int?      @map("group_count")
  teamsPerGroup Int?      @map("teams_per_group")
  advanceCount  Int?      @map("advance_count")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament    TournamentNew       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams         TournamentTeam[]
  groups        TournamentGroup[]
  matches       TournamentMatch[]
  standings     TournamentStanding[]
  topScorers    TournamentTopScorer[]
  teamRegs      TournamentTeamReg[]

  @@map("tournament_categories")
}

/// الفرق المسجلة
model TournamentTeam {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  categoryId    String?   @map("category_id")
  name          String
  logoUrl       String?   @map("logo_url")
  clubName      String?   @map("club_name")
  city          String?
  country       String?
  contactName   String?   @map("contact_name")
  contactPhone  String?   @map("contact_phone")
  contactEmail  String?   @map("contact_email")
  /// pending | approved | rejected | withdrawn
  status        String    @default("pending")
  seed          Int?
  groupId       String?   @map("group_id")
  notes         String?
  registeredAt  DateTime  @default(now()) @map("registered_at")
  approvedAt    DateTime? @map("approved_at")

  tournament    TournamentNew       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category      TournamentCategory? @relation(fields: [categoryId], references: [id])
  group         TournamentGroup?    @relation(fields: [groupId], references: [id])
  players       TournamentPlayer[]
  homeMatches   TournamentMatch[]   @relation("MatchHomeTeam")
  awayMatches   TournamentMatch[]   @relation("MatchAwayTeam")
  matchEvents   TournamentMatchEvent[]
  standing      TournamentStanding?
  registration  TournamentTeamReg?

  @@map("tournament_teams")
}

/// لاعبو كل فريق
model TournamentPlayer {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  teamId        String    @map("team_id")
  name          String
  dateOfBirth   String?   @map("date_of_birth")
  position      String?
  jerseyNumber  Int?      @map("jersey_number")
  photoUrl      String?   @map("photo_url")
  isCaptain     Boolean   @default(false) @map("is_captain")
  /// active | suspended | injured
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")

  team          TournamentTeam       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchEvents   TournamentMatchEvent[]
  topScorer     TournamentTopScorer?

  @@map("tournament_players")
}

/// تسجيل الفرق + الدفع
model TournamentTeamReg {
  id              String    @id @default(uuid())
  tournamentId    String    @map("tournament_id")
  categoryId      String?   @map("category_id")
  teamId          String?   @unique @map("team_id")
  /// pending | paid | partial | free | refunded
  paymentStatus   String    @default("pending") @map("payment_status")
  paymentAmount   Decimal?  @map("payment_amount") @db.Decimal(12, 2)
  paymentMethod   String?   @map("payment_method")
  receiptUrl      String?   @map("receipt_url")
  receiptNumber   String?   @map("receipt_number")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tournament      TournamentNew       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category        TournamentCategory? @relation(fields: [categoryId], references: [id])
  team            TournamentTeam?     @relation(fields: [teamId], references: [id])

  @@map("tournament_team_regs")
}

/// المجموعات (A, B, C...)
model TournamentGroup {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  categoryId    String    @map("category_id")
  name          String
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament    TournamentNew       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category      TournamentCategory  @relation(fields: [categoryId], references: [id])
  teams         TournamentTeam[]
  matches       TournamentMatch[]
  standings     TournamentStanding[]

  @@map("tournament_groups")
}

/// جدول المباريات
model TournamentMatch {
  id                 String    @id @default(uuid())
  tournamentId       String    @map("tournament_id")
  categoryId         String?   @map("category_id")
  groupId            String?   @map("group_id")
  /// group_stage | round_of_32 | round_of_16 | quarter_final | semi_final | third_place | final
  round              String    @default("group_stage")
  matchNumber        Int?      @map("match_number")
  homeTeamId         String?   @map("home_team_id")
  awayTeamId         String?   @map("away_team_id")
  homeScore          Int?      @map("home_score")
  awayScore          Int?      @map("away_score")
  homePenalties      Int?      @map("home_penalties")
  awayPenalties      Int?      @map("away_penalties")
  venue              String?
  scheduledAt        DateTime? @map("scheduled_at")
  playedAt           DateTime? @map("played_at")
  /// scheduled | live | completed | postponed | cancelled
  status             String    @default("scheduled")
  winnerId           String?   @map("winner_id")
  nextMatchId        String?   @map("next_match_id")
  /// home | away
  nextMatchPosition  String?   @map("next_match_position")
  refereeName        String?   @map("referee_name")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tournament         TournamentNew       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category           TournamentCategory? @relation(fields: [categoryId], references: [id])
  group              TournamentGroup?    @relation(fields: [groupId], references: [id])
  homeTeam           TournamentTeam?     @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam           TournamentTeam?     @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])
  events             TournamentMatchEvent[]

  @@map("tournament_matches")
}

/// أحداث المباراة (أهداف، بطاقات، تبديلات)
model TournamentMatchEvent {
  id              String    @id @default(uuid())
  matchId         String    @map("match_id")
  teamId          String?   @map("team_id")
  playerId        String?   @map("player_id")
  /// goal | own_goal | yellow_card | red_card | second_yellow | sub_in | sub_out | penalty_scored | penalty_missed
  eventType       String    @map("event_type")
  minute          Int?
  extraMinute     Int?      @map("extra_minute")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  match           TournamentMatch      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team            TournamentTeam?      @relation(fields: [teamId], references: [id])
  player          TournamentPlayer?    @relation(fields: [playerId], references: [id])

  @@map("tournament_match_events")
}

/// ترتيب الفرق (يُحدَّث تلقائياً عند إدخال النتائج)
model TournamentStanding {
  id             String    @id @default(uuid())
  tournamentId   String    @map("tournament_id")
  categoryId     String    @map("category_id")
  teamId         String    @unique @map("team_id")
  groupId        String?   @map("group_id")
  position       Int?
  played         Int       @default(0)
  won            Int       @default(0)
  drawn          Int       @default(0)
  lost           Int       @default(0)
  goalsFor       Int       @default(0) @map("goals_for")
  goalsAgainst   Int       @default(0) @map("goals_against")
  goalDifference Int       @default(0) @map("goal_difference")
  points         Int       @default(0)
  form           String?
  updatedAt      DateTime  @updatedAt @map("updated_at")

  team           TournamentTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  category       TournamentCategory  @relation(fields: [categoryId], references: [id])
  group          TournamentGroup?    @relation(fields: [groupId], references: [id])

  @@map("tournament_standings")
}

/// قائمة الهدافين (تُحدَّث تلقائياً)
model TournamentTopScorer {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  categoryId    String    @map("category_id")
  playerId      String    @unique @map("player_id")
  teamId        String    @map("team_id")
  goals         Int       @default(0)
  assists       Int       @default(0)
  yellowCards   Int       @default(0) @map("yellow_cards")
  redCards      Int       @default(0) @map("red_cards")
  minutesPlayed Int       @default(0) @map("minutes_played")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  player        TournamentPlayer    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  category      TournamentCategory  @relation(fields: [categoryId], references: [id])

  @@map("tournament_top_scorers")
}

/// إشعارات البطولة
model TournamentNotif {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  /// match_reminder | result | standings | general
  type          String
  title         String
  body          String
  /// all | team
  target        String    @default("all")
  targetId      String?   @map("target_id")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament    TournamentNew @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_notifications")
}

